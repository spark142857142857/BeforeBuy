{
  "name": "before-buy",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/app.test.mjs tests/use-cases.test.mjs && uv run python -m unittest discover -s pipeline/tests",
    "test:use-cases": "npm run build && node --test tests/use-cases.test.mjs",
    "data:check": "node scripts/check-snapshot.mjs",
    "data:krx": "uv run python pipeline/collect_krx_master.py",
    "data:dart:map": "uv run python pipeline/collect_dart_business.py --corp-codes-only",
    "data:dart:sample": "uv run python pipeline/collect_dart_business.py --symbols \"005930,035420,105560,012450,000020,068270,296520,317860,000650,088260\" --output work/dart_annual_sample.json --refresh",
    "data:dart": "uv run python pipeline/collect_dart_business.py",
    "data:profiles": "uv run python pipeline/prepare_web_profiles.py",
    "data:similarity": "uv run python pipeline/build_similarity.py",
    "data:global": "uv run python pipeline/build_global_links.py",
    "data:derive": "npm run data:profiles && npm run data:similarity && npm run data:global && npm run data:check",
    "data:refresh": "npm run data:krx && npm run data:dart && npm run data:derive",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern outputs --ignore-pattern work --ignore-pattern .venv --ignore-pattern data"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module"
}
